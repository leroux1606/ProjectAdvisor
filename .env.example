# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Stripe ────────────────────────────────────────────────────────────────────
# Use test keys (sk_test_...) during development, live keys (sk_live_...) in production
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret — get from Stripe Dashboard or `stripe listen` CLI output
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — create these in your Stripe Dashboard (Products → Add Product)
# Starter Pack: £15 one-time, 10 credits
STRIPE_PRICE_CREDITS_10=price_...

# Team Pack: £50 one-time, 50 credits
STRIPE_PRICE_CREDITS_50=price_...

# Pro Monthly: £29/month subscription
STRIPE_PRICE_PRO_MONTHLY=price_...

# Pro Annual: £249/year subscription
STRIPE_PRICE_PRO_ANNUAL=price_...

# ── App ───────────────────────────────────────────────────────────────────────
# Public URL of your app (used for Stripe redirect URLs)
APP_URL=http://localhost:3000

# Port for the webhook receiver (Flask server)
WEBHOOK_PORT=4242

# Temporary local testing bypass for usage/payment gates
BYPASS_PAYMENT=false
